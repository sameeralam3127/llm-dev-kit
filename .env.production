# Ollama Configuration
OLLAMA_HOST=http://host.docker.internal:11434

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# ChromaDB Configuration
CHROMA_HOST=chroma
CHROMA_PORT=8000

# Backend Configuration
BACKEND_URL=http://backend:8000
BACKEND_PORT=8000

# Agent Service Configuration
AGENT_URL=http://agent:8001
AGENT_PORT=8001

# Open WebUI Configuration
WEBUI_SECRET_KEY=change-this-to-a-secure-random-string-in-production
WEBUI_AUTH=true
WEBUI_PORT=3000

# Environment
ENVIRONMENT=production

# Logging
LOG_LEVEL=INFO

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# RAG Configuration
ENABLE_RAG=true
ENABLE_WEB_SEARCH=true
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Model Configuration
DEFAULT_MODEL=llama2
TEMPERATURE=0.7
MAX_TOKENS=2000