# ------------------------------------------------------------------ Offline LLM
# Host Ollama is the default. If you run the ollama compose profile instead,
# set OLLAMA_HOST=http://ollama:11434
OLLAMA_HOST=http://localhost:11434
DEFAULT_CHAT_MODEL=llama3.1
DEFAULT_EMBEDDING_MODEL=nomic-embed-text
REQUEST_TIMEOUT_SECONDS=120

# --------------------------------------------------- Cloud providers (optional)
# Leave empty for a fully offline stack. With a key set, cloud models become
# available as "openai/<model>" and "anthropic/<model>". OPENAI_BASE_URL may
# point at any OpenAI-compatible API (Groq, Together, vLLM, ...).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ------------------------------------------------ Service URLs (local dev only)
# Inside docker compose these are set per service; override when running a
# service directly on your machine.
LLM_SERVICE_URL=http://localhost:8010
RAG_SERVICE_URL=http://localhost:8020

# ----------------------------------------------------------------------- Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
GITHUB_CACHE_TTL=600

# --------------------------------------------------------------- Vector stores
CHROMA_HOST=localhost
CHROMA_PORT=8000
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=github_documents
RETRIEVER_SCORE_THRESHOLD=0.72

# ----------------------------------------------------------------------- Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_DOCS_CHANGED=docs.changed
KAFKA_TOPIC_DOCS_INDEXED=docs.indexed
KAFKA_TOPIC_DOCS_FAILED=docs.failed
KAFKA_TOPIC_CACHE_INVALIDATE=cache.invalidate

# ------------------------------------------------------- GitHub documentation sync
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=
GITHUB_DEFAULT_BRANCH=main
